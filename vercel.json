{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/admin/models/live-test/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/digital-product/generate/route.ts": {
      "maxDuration": 120
    }
  }
}
